# Обязательно — токен бота от @BotFather
BOT_TOKEN=

# Опционально (показаны значения по умолчанию)
CAPTCHA_TIMEOUT_SECONDS=30
MAX_ATTEMPTS=3
LOG_LEVEL=info
NEWCOMER_DAYS=7

# Через сколько дней молчания бот поздравит вернувшегося с "ухты!".
# 0 — выключить эти анонсы.
SILENT_ANNOUNCE_DAYS=30

# Путь к SQLite-файлу.
# В Docker compose он переопределяется на /data/bot.db (volume bot-data).
# Локально по умолчанию — ./bot.db
# DB_PATH=./bot.db

# Опционально — белый список chat_id через запятую.
# Если задан, бот игнорирует новых участников в других чатах.
# Если пусто — работает во всех чатах, где его сделали админом.
# ALLOWED_CHATS=-1001234567890,-1009876543210

# Опционально — Telegram user_id владельцев бота через запятую.
# Владельцы:
#   • получают уведомления о старте/остановке бота в личку;
#   • могут запускать /stats в любом чате, где работает бот, без проверки
#     статуса админа в этом чате.
# Чтобы узнать свой user_id: напиши боту /start в личку — он покажет ID.
# ВАЖНО: для получения уведомлений владелец должен был хоть раз написать
# боту (иначе Telegram не позволит боту инициировать переписку).
# OWNER_IDS=123456789
